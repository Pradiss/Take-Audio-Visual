<section id="contato" class="cta-section relative z-10 h-screen overflow-hidden bg-black text-white">
  <div class="cta-bg absolute inset-0">
    <img
      src="/IMG_3606.webp"
      alt=""
      class="h-[120%] w-full object-cover"
    />
  </div>

  <div class="absolute inset-0 bg-black/65"></div>

  <div class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center">
    <h2 class="cta-title max-w-5xl text-[48px] font-medium leading-[52px] tracking-[-0.04em] md:text-[72px] md:leading-[76px]">
      Sua marca merece ser lembrada.
    </h2>

    <a
      href="https://wa.me/5519999999999"
      class="cta-button mt-10 inline-flex items-center gap-4 rounded-full bg-white px-8 py-4 text-sm font-bold text-black transition hover:scale-105 hover:bg-red-600 hover:text-white"
    >
      Vamos começar
      <span>→</span>
    </a>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.to(".cta-bg img", {
    yPercent: -18,
    ease: "none",
    scrollTrigger: {
      trigger: ".cta-section",
      start: "top bottom",
      end: "bottom top",
      scrub: 1.4,
    },
  });

  gsap.from(".cta-title", {
    y: 60,
    opacity: 0,
    duration: 1,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".cta-section",
      start: "top 70%",
    },
  });

  gsap.from(".cta-button", {
    y: 30,
    opacity: 0,
    duration: 0.8,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".cta-section",
      start: "top 60%",
    },
  });
</script>