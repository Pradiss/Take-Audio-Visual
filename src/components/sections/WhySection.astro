<section id="why" class="relative bg-[#f4efe7] px-6 py-28 text-black md:py-36">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-14 md:grid-cols-[0.8fr_1.2fr] md:items-start">
      <div>
        <h2 class="why-label text-xl font-black tracking-tight md:text-2xl">
          Por que a TAKE
        </h2>
      </div>
      

      <div>
        <div
          class="why-text max-w-6xl text-[34px] leading-[48px] font-medium tracking-[-0.04em]"
        >
          <div class="why-line">
            Sua marca está mudando. Não é só sobre produzir vídeos — é sobre
            construir percepção. Nós ajudamos você a se posicionar com clareza,
            autoridade, e impacto em cada frame.
          </div>
        </div>
      </div>
    </div>

    <div
      class="why-preview mt-16 overflow-hidden rounded-[2rem] bg-black md:mt-18"
    >
      <video
        src="/videos/IMG_3804.MOV"
        autoplay
        playsinline
        muted
        loop
        class="h-[360px] w-full object-cover md:h-[620px]"></video>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".why-label", {
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power4.out",
    scrollTrigger: {
      trigger: "#why",
      start: "top 75%",
    },
  });

  gsap.fromTo(
    ".why-line",
    { color: "rgba(0, 0, 0, 0.25)" },
    {
      color: "rgba(0, 0, 0, 1)",
      stagger: 0.25,
      ease: "none",
      scrollTrigger: {
        trigger: ".why-text",
        start: "top 75%",
        end: "bottom 45%",
        scrub: true,
      },
    },
  );

  gsap.from(".why-preview", {
    clipPath: "inset(0 0 100% 0)",
    duration: 1.2,
    ease: "power4.out",
    scrollTrigger: {
      trigger: ".why-preview",
      start: "top 80%",
    },
  });
</script>
