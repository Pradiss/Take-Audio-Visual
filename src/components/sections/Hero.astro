---
import Button from "../global/Button.astro";
---

<section id="inicio" class="hero_root relative overflow-hidden bg-[#f4efe7]">
  <div class="hero_top relative h-[180vh] overflow-hidden">
    <div class="hero_sticky sticky top-0 h-screen min-h-[720px] overflow-hidden">
      <div class="hero_bg absolute inset-0">
        <div class="hero_back absolute inset-0 z-0">
          <img
            src="/images/back.webp"
            alt=""
            class="h-full w-full object-cover"
          />
        </div>

        <div class="hero_house absolute inset-x-0 bottom-[-6%] z-[2] mx-auto w-[78vw] max-w-[1180px]">
          <img src="/images/house.webp" alt="" class="w-full" />
        </div>

        <div class="hero_clouds pointer-events-none absolute inset-0 z-[3]">
          <div class="hero_cloud_left absolute left-[-18%] top-[26%] w-[70vw] max-w-[900px]">
            <img src="/images/cloud.webp" alt="" class="w-full" />
          </div>

          <div class="hero_cloud_right absolute right-[-18%] top-[26%] w-[70vw] max-w-[900px]">
            <img src="/images/cloud.webp" alt="" class="w-full" />
          </div>
        </div>

        <div class="hero_logo_layer pointer-events-none absolute inset-x-0 bottom-[8%] z-[4] flex justify-center opacity-0">
          <div class="relative mx-auto w-[82vw] max-w-[1100px]">
            <svg
              class="hero_logo_svg mx-auto w-full"
              viewBox="0 0 1600 520"
              xmlns="http://www.w3.org/2000/svg"
            >
              <defs>
                <clipPath id="take-logo-clip">
                  <text
                    x="50%"
                    y="44%"
                    text-anchor="middle"
                    dominant-baseline="middle"
                    font-size="260"
                    font-weight="900"
                    font-family="Arial Black, Impact, sans-serif"
                    letter-spacing="-18"
                  >
                    TAKE
                  </text>

                  <text
                    x="50%"
                    y="75%"
                    text-anchor="middle"
                    dominant-baseline="middle"
                    font-size="72"
                    font-weight="600"
                    font-family="Arial, sans-serif"
                    letter-spacing="22"
                  >
                    AUDIOVISUAL
                  </text>
                </clipPath>
              </defs>

              <image
                class="hero_logo_fill"
                href="/images/house.webp"
                x="0"
                y="0"
                width="1600"
                height="520"
                preserveAspectRatio="xMidYMid slice"
                clip-path="url(#take-logo-clip)"
                opacity="0"
              />

              <g
                class="hero_logo_outline"
                fill="transparent"
                stroke="rgba(255,255,255,0.95)"
                stroke-width="2"
              >
                <text
                  x="50%"
                  y="44%"
                  text-anchor="middle"
                  dominant-baseline="middle"
                  font-size="260"
                  font-weight="900"
                  font-family="Arial Black, Impact, sans-serif"
                  letter-spacing="-18"
                >
                  TAKE
                </text>

                <text
                  x="50%"
                  y="75%"
                  text-anchor="middle"
                  dominant-baseline="middle"
                  font-size="72"
                  font-weight="600"
                  font-family="Arial, sans-serif"
                  letter-spacing="22"
                >
                  AUDIOVISUAL
                </text>
              </g>
            </svg>
          </div>
        </div>

        <div class="hero_smoke absolute inset-x-0 bottom-[-12%] z-[5]">
          <img src="/images/smoke.webp" alt="" class="w-full object-cover" />
        </div>
      </div>

      <div class="hero_content relative z-[6] mx-auto flex h-full max-w-7xl flex-col items-center justify-center px-6 pt-28 text-center">
        <h1 class="hero_title text-[58px] font-black leading-[0.9] tracking-[-0.065em] text-black md:text-[118px] lg:text-[148px]">
          <span class="hero_word inline-block overflow-hidden px-2">
            <span class="inline-block">Crie</span>
          </span>

          <span class="hero_word inline-block overflow-hidden px-2">
            <span class="inline-block">Vídeos</span>
          </span>

          <span class="hero_word inline-block overflow-hidden px-2">
            <span class="inline-block">Que</span>
          </span>

          <span class="hero_word inline-block overflow-hidden px-2">
            <span class="inline-block">Marcam</span>
          </span>
        </h1>

        <div class="hero_text mt-6 text-base font-medium text-black/55 md:text-lg">
          <p>
            Produção audiovisual. Direção criativa.
            <span class="text-black/85">
              Uma forma clara de posicionar sua marca.
            </span>
          </p>
        </div>

        <div class="hero_actions mt-8">
          <Button href="/portfolio" text="Ver portfólio" variant="dark" />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.set(".hero_logo_outline text", {
    strokeDasharray: 2200,
    strokeDashoffset: 2200,
  });

  gsap.set(".hero_logo_fill", {
    opacity: 0,
  });

  const intro = gsap.timeline({
    defaults: {
      ease: "power4.out",
    },
  });

  intro
    .from("#site-header", {
      y: -70,
      opacity: 0,
      duration: 0.9,
    })
    .from(
      ".hero_back",
      {
        scale: 1.08,
        opacity: 0,
        duration: 1.2,
      },
      "-=0.6"
    )
    .from(
      ".hero_house",
      {
        yPercent: 12,
        scale: 0.96,
        opacity: 0,
        duration: 1.2,
      },
      "-=1"
    )
    .from(
      ".hero_cloud_left",
      {
        xPercent: -15,
        opacity: 0,
        duration: 1.2,
      },
      "-=1"
    )
    .from(
      ".hero_cloud_right",
      {
        xPercent: 15,
        opacity: 0,
        duration: 1.2,
      },
      "-=1.1"
    )
    .from(
      ".hero_word span",
      {
        yPercent: 105,
        duration: 1,
        stagger: 0.08,
      },
      "-=0.65"
    )
    .from(
      ".hero_text",
      {
        y: 24,
        opacity: 0,
        duration: 0.75,
      },
      "-=0.4"
    )
    .from(
      ".hero_actions",
      {
        y: 24,
        opacity: 0,
        duration: 0.75,
      },
      "-=0.45"
    );

  const scrollTl = gsap.timeline({
    scrollTrigger: {
      trigger: ".hero_top",
      start: "top top",
      end: "bottom bottom",
      scrub: 1.2,
    },
  });

  scrollTl
    .to(".hero_content", {
      yPercent: 14,
      scale: 0.94,
      opacity: 0,
      ease: "none",
    })
    .to(
      ".hero_back",
      {
        yPercent: -6,
        scale: 1.04,
        ease: "none",
      },
      0
    )
    .to(
      ".hero_house",
      {
        yPercent: -18,
        scale: 1.04,
        ease: "none",
      },
      0
    )
    .to(
      ".hero_cloud_left",
      {
        xPercent: -8,
        ease: "none",
      },
      0
    )
    .to(
      ".hero_cloud_right",
      {
        xPercent: 8,
        ease: "none",
      },
      0
    )
    .to(
      ".hero_smoke",
      {
        yPercent: 55,
        ease: "none",
      },
      0
    )
    .to(
      ".hero_logo_layer",
      {
        yPercent: -18,
        opacity: 1,
        ease: "none",
      },
      0.42
    )
    .to(
      ".hero_logo_outline text",
      {
        strokeDashoffset: 0,
        stagger: 0.08,
        ease: "none",
      },
      0.48
    )
    .to(
      ".hero_logo_fill",
      {
        opacity: 1,
        ease: "none",
      },
      0.68
    )
    .to(
      ".hero_logo_outline",
      {
        opacity: 0.6,
        ease: "none",
      },
      0.78
    );
</script>