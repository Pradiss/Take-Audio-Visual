<section id="inicio" class="hero_root relative overflow-hidden bg-[#f4efe7]">
  <div class="hero_top relative h-screen min-h-[720px] overflow-hidden">
    <div class="hero_bg absolute inset-0">
      <div class="hero_back absolute inset-0 z-0">
        <img
          src="/images/back.webp"
          alt=""
          class="h-full w-full object-cover"
        />
      </div>

      <div class="hero_clouds pointer-events-none absolute inset-0 z-[1]">
        <div class="hero_cloud_left absolute left-[-20%] top-[22%] w-[70vw] max-w-[900px]">
          <img src="/images/cloud.webp" alt="" class="w-full" />
        </div>

        <div class="hero_cloud_right absolute right-[-20%] top-[24%] w-[70vw] max-w-[900px]">
          <img src="/images/cloud.webp" alt="" class="w-full" />
        </div>
      </div>
    </div>

    <div class="hero_content relative z-[5] mx-auto flex h-full max-w-7xl flex-col items-center justify-center px-6 pt-28 text-center">
      <div class="hero_title" aria-label="Crie Vídeos Que Marcam">
        <h1 class="text-[58px] font-black leading-[0.9] tracking-[-0.065em] text-black md:text-[118px] lg:text-[148px]">
          <span class="hero_word inline-block overflow-hidden px-2">
            <span class="inline-block">Crie</span>
          </span>

          <span class="hero_word inline-block overflow-hidden px-2">
            <span class="inline-block">Vídeos</span>
          </span>

          <span class="hero_word inline-block overflow-hidden px-2">
            <span class="inline-block">Que</span>
          </span>

          <span class="hero_word inline-block overflow-hidden px-2">
            <span class="inline-block">Marcam</span>
          </span>
        </h1>
      </div>

      <div class="hero_text mt-6 text-base font-medium text-black/55 md:text-lg">
        <p>
          Produção audiovisual. Direção criativa.
          <span class="text-black/85">Uma forma clara de posicionar sua marca.</span>
        </p>
      </div>

      <div class="hero_actions mt-8">
        <a
          href="#servicos"
          class="inline-flex items-center gap-3 rounded-full bg-black px-6 py-3 text-sm font-bold text-white transition hover:scale-105 hover:bg-red-600"
        >
          Conheça os serviços
          <span>→</span>
        </a>
      </div>
    </div>
  </div>

  <div class="hero_overlap pointer-events-none relative z-[6] -mt-36 h-52 overflow-hidden">
    <div class="absolute inset-x-0 top-0">
      <img src="/images/smoke.webp" alt="" class="w-full object-cover" />
    </div>

    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#f4efe7]"></div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({
    defaults: {
      ease: "power4.out",
    },
  });

  tl.from("#site-header", {
    y: -70,
    opacity: 0,
    duration: 0.9,
  })
    .from(
      ".hero_back",
      {
        scale: 1.08,
        opacity: 0,
        duration: 1.2,
      },
      "-=0.6"
    )
    .from(
      ".hero_cloud_left",
      {
        xPercent: -15,
        opacity: 0,
        duration: 1.2,
      },
      "-=1"
    )
    .from(
      ".hero_cloud_right",
      {
        xPercent: 15,
        opacity: 0,
        duration: 1.2,
      },
      "-=1.1"
    )
    .from(
      ".hero_word span",
      {
        yPercent: 105,
        duration: 1,
        stagger: 0.08,
      },
      "-=0.65"
    )
    .from(
      ".hero_text",
      {
        y: 24,
        opacity: 0,
        duration: 0.75,
      },
      "-=0.4"
    )
    .from(
      ".hero_actions",
      {
        y: 24,
        opacity: 0,
        duration: 0.75,
      },
      "-=0.45"
    );

  gsap.to(".hero_content", {
    yPercent: 20,
    scale: 0.9,
    opacity: 0,
    ease: "none",
    scrollTrigger: {
      trigger: ".hero_top",
      start: "top top",
      end: "bottom top",
      scrub: true,
    },
  });

  gsap.to(".hero_cloud_left", {
    xPercent: -15,
    ease: "none",
    scrollTrigger: {
      trigger: ".hero_top",
      start: "top top",
      end: "bottom top",
      scrub: true,
    },
  });

  gsap.to(".hero_cloud_right", {
    xPercent: 15,
    ease: "none",
    scrollTrigger: {
      trigger: ".hero_top",
      start: "top top",
      end: "bottom top",
      scrub: true,
    },
  });
</script>