---
import Button from "../global/Button.astro";
---

<section id="inicio" class="hero_root relative min-h-screen overflow-hidden bg-black text-white">
  <!-- IMAGEM DE FUNDO -->
  <div class="hero_back absolute inset-0 z-0">
    <img
      src="/arquitetura/IMG_0044.webp"
      alt=""
      class="h-full w-full object-cover"
    />
  </div>

  <!-- OVERLAYS CINEMATOGRÁFICOS -->
  <div class="absolute inset-0 z-[1] bg-black/55"></div>
  <div class="absolute inset-0 z-[1] bg-gradient-to-r from-black/80 via-black/35 to-black/20"></div>
  <div class="absolute inset-0 z-[1] bg-gradient-to-t from-black/70 via-transparent to-black/35"></div>

  <!-- RUÍDO / TEXTURA -->
  <div class="hero_noise pointer-events-none absolute inset-0 z-[2] opacity-[0.08]"></div>

  <!-- CONTEÚDO PRINCIPAL -->
  <div
    class="relative z-10 mx-auto flex min-h-screen max-w-[1750px] flex-col justify-end px-6 pb-16 pt-32 md:px-10 lg:pb-24"
  >
    <div class="max-w-[900px]">
      <p class="hero_eyebrow mb-5 text-xs font-semibold uppercase tracking-[0.35em] text-white/65">
        TAKE AUDIOVISUAL
      </p>

      <h1
        class="hero_title text-[clamp(4.5rem,7vw,9rem)] font-black leading-[0.82] tracking-[-0.085em] text-white"
      >
        Crie vídeos que marcam
      </h1>

      <p class="hero_text mt-6 max-w-[620px] text-base font-medium leading-[1.55] text-white/70 md:text-xl">
        Produção audiovisual, direção criativa e acabamento visual para marcas que querem presença, impacto e memória.
      </p>

      <div class="hero_actions mt-8">
        <Button href="/portfolio" text="Ver portfólio" variant="light" />
      </div>
    </div>

    <!-- INFO RODAPÉ -->
    <div class="mt-16 grid gap-6 text-xs font-semibold uppercase tracking-[0.22em] text-white/45 md:grid-cols-3">
      <div>
        <span class="block text-white/80">Direção</span>
        Criativa e visual
      </div>

      <div>
        <span class="block text-white/80">Captação</span>
        Imagem, luz e movimento
      </div>

      <div>
        <span class="block text-white/80">Entrega</span>
        Conteúdo com presença
      </div>
    </div>
  </div>

  <!-- CARD FLUTUANTE -->
  <div
    class="hero_card absolute bottom-[18%] right-[5%] z-20 hidden w-[320px] rounded-2xl border border-white/10 bg-white/10 p-3 shadow-2xl backdrop-blur-md lg:block"
  >
    <div class="overflow-hidden rounded-xl">
      <img
        src="/arquitetura/IMG_0044.webp"
        alt=""
        class="h-[160px] w-full object-cover"
      />
    </div>

    <div class="mt-3 flex items-center justify-between px-1">
      <div>
        <p class="text-sm font-semibold text-white">Frame de impacto</p>
        <p class="text-xs text-white/50">Direção audiovisual</p>
      </div>

      <span class="h-2 w-2 rounded-full bg-white"></span>
    </div>
  </div>
</section>

<style>
  .hero_title,
  .hero_text {
    text-wrap: balance;
  }

  .hero_noise {
    background-image:
      radial-gradient(circle at 20% 20%, white 0.5px, transparent 0.5px),
      radial-gradient(circle at 80% 30%, white 0.5px, transparent 0.5px),
      radial-gradient(circle at 50% 80%, white 0.5px, transparent 0.5px);
    background-size: 18px 18px;
  }
</style>

<script>
  import gsap from "gsap";

  const hero = document.querySelector(".hero_root");

  if (hero) {
    const intro = gsap.timeline({
      defaults: {
        ease: "power4.out",
      },
    });

    intro
      .from(".hero_back img", {
        scale: 1.08,
        opacity: 0,
        duration: 1.4,
      })
      .from(
        ".hero_eyebrow",
        {
          y: 20,
          opacity: 0,
          duration: 0.7,
        },
        "-=0.8"
      )
      .from(
        ".hero_title",
        {
          y: 60,
          opacity: 0,
          duration: 1,
        },
        "-=0.45"
      )
      .from(
        ".hero_text",
        {
          y: 28,
          opacity: 0,
          duration: 0.8,
        },
        "-=0.5"
      )
      .from(
        ".hero_actions",
        {
          y: 24,
          opacity: 0,
          duration: 0.75,
        },
        "-=0.5"
      )
      .from(
        ".hero_card",
        {
          x: 40,
          y: 30,
          opacity: 0,
          duration: 0.9,
        },
        "-=0.55"
      );
  }
</script>