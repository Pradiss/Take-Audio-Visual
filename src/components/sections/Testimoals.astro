---
import { ArrowLeft, ArrowRight } from "lucide-astro";
---

<section id="depoimentos" class="overflow-hidden bg-[#030303] px-6 py-20 text-white sm:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="mb-8 flex items-center gap-2 text-sm">
      <span class="h-1.5 w-1.5 rounded-full bg-white"></span>
      <p>Depoimentos</p>
      <span class="text-zinc-600">/ (<strong id="testimonial-total">04</strong>)</span>
    </div>

    

    <blockquote
      id="testimonial-text"
      class="min-h-[160px] max-w-3xl text-2xl font-medium leading-snug tracking-[-0.03em] text-zinc-50 sm:text-3xl lg:text-4xl"
    ></blockquote>

    <div class="mt-10 flex items-center gap-5">
      <img
        id="testimonial-image"
        src=""
        alt="Cliente"
        class="h-20 w-20 rounded-lg object-cover grayscale sm:h-24 sm:w-24"
      />

      <div>
        <h3 id="testimonial-name" class="text-lg font-medium sm:text-xl"></h3>

        <p class="mt-1 text-sm text-zinc-500">
          <span id="testimonial-role"></span>
          <strong id="testimonial-location" class="font-medium text-white"></strong>
        </p>
      </div>
    </div>

    <div class="mt-8 h-[2px] w-full max-w-sm overflow-hidden rounded-full bg-zinc-600">
      <span
        id="testimonial-progress-bar"
        class="block h-full rounded-full bg-white transition-all duration-500 ease-out"
      ></span>
    </div>

    <div class="mt-8 flex gap-4">
      <button
        type="button"
        id="testimonial-prev"
        aria-label="Anterior"
        class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-white bg-transparent text-white transition duration-300 hover:bg-white hover:text-black"
      >
        <ArrowLeft class="h-5 w-5" strokeWidth={2} />
      </button>

      <button
        type="button"
        id="testimonial-next"
        aria-label="Próximo"
        class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-white bg-transparent text-white transition duration-300 hover:bg-white hover:text-black"
      >
        <ArrowRight class="h-5 w-5" strokeWidth={2} />
      </button>
    </div>
  </div>
</section>

<style>
  .testimonial-fade {
    animation: testimonialFade 0.55s ease both;
  }

  @keyframes testimonialFade {
    from {
      opacity: 0;
      transform: translateY(12px);
      filter: blur(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }
</style>

<script is:inline>
  const testimonials = [
    {
      text: "“I usually hate getting my photo taken, but this felt totally different. Super relaxed, nothing forced. The photos actually look like me, not a version of me trying too hard.”",
      name: "Perlima",
      role: "Projeto em",
      location: "Vídeo Institucional",
      image: "ensaios/IMG_3804.webp",
    },
    {
      text: "“I usually hate getting my photo taken, but this felt totally different. Super relaxed, nothing forced. The photos actually look like me, not a version of me trying too hard.”",
      name: "Renato Martins",
      role: "Projeto em",
      location: "Vídeo Institucional",
      image: "ensaios/IMG_3805.webp",
    },
    {
      text: "“I usually hate getting my photo taken, but this felt totally different. Super relaxed, nothing forced. The photos actually look like me, not a version of me trying too hard.”",
      name: "Camila Andrade",
      role: "Projeto em",
      location: "Vídeo Institucional",
      image: "ensaios/IMG_3806.webp",
    },
    {
      text: "“I usually hate getting my photo taken, but this felt totally different. Super relaxed, nothing forced. The photos actually look like me, not a version of me trying too hard.”",
      name: "Juliana Costa",
      role: "Projeto em",
      location: "Vídeo Institucional",
      image: "ensaios/IMG_3807.webp",
    },
  ];

  const textEl = document.querySelector("#testimonial-text");
  const imageEl = document.querySelector("#testimonial-image");
  const nameEl = document.querySelector("#testimonial-name");
  const roleEl = document.querySelector("#testimonial-role");
  const locationEl = document.querySelector("#testimonial-location");
  const progressEl = document.querySelector("#testimonial-progress-bar");
  const totalEl = document.querySelector("#testimonial-total");
  const prevBtn = document.querySelector("#testimonial-prev");
  const nextBtn = document.querySelector("#testimonial-next");

  let currentIndex = 0;

  totalEl.textContent = String(testimonials.length).padStart(2, "0");

  function animateElement(element) {
    element.classList.remove("testimonial-fade");
    void element.offsetWidth;
    element.classList.add("testimonial-fade");
  }

  function renderTestimonial() {
    const testimonial = testimonials[currentIndex];

    textEl.textContent = testimonial.text;
    imageEl.src = testimonial.image;
    nameEl.textContent = testimonial.name;
    roleEl.textContent = testimonial.role + " ";
    locationEl.textContent = testimonial.location;

    progressEl.style.width = `${((currentIndex + 1) / testimonials.length) * 100}%`;

    [textEl, imageEl, nameEl, roleEl, locationEl].forEach(animateElement);
  }

  nextBtn.addEventListener("click", () => {
    currentIndex = (currentIndex + 1) % testimonials.length;
    renderTestimonial();
  });

  prevBtn.addEventListener("click", () => {
    currentIndex = (currentIndex - 1 + testimonials.length) % testimonials.length;
    renderTestimonial();
  });

  renderTestimonial();
</script>