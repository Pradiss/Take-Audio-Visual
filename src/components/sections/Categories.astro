---
import { ArrowRight } from "lucide-astro";
import Button from "../global/Button.astro";

const cards = [
  {
    title: `Fotografia\nde Produtos`,
    image: "/IMG_3604.webp",
    alt: "Fotografia de Produtos",
    text: "Imagens profissionais para destacar detalhes, valorizar sua marca e aumentar a percepção de qualidade.",
  },
  {
    title: `Arquitetura\ne Interiores`,
    image: "/IMG_3606.webp",
    alt: "Arquitetura e Interiores",
    text: "Produções visuais para apresentar ambientes, projetos arquitetônicos e espaços com impacto visual.",
  },
  {
    title: `Retrato\nCorporativo`,
    image: "/IMG_3605.webp",
    alt: "Retrato Corporativo",
    text: "Retratos profissionais para fortalecer autoridade, posicionamento e presença digital da sua marca.",
  },
];
---

<section id="features" class="bg-white text-[#151717]">
  <div class="mx-auto max-w-7xl px-6 py-24 md:py-32">
    <div class="grid gap-12 md:grid-cols-[1fr_1.25fr] md:items-start">
      <div>
        <h2
          class="text-[50px] font-medium leading-[56px] tracking-[-0.06em] md:text-[70px] md:leading-[72px]"
        >
          Produções que vão
          <span class="block">
            além da <span class="text-[#151717]/35">imagem.</span>
          </span>
        </h2>
      </div>

      <div class="pt-2 md:max-w-[620px]">
        <p
          class="text-[24px] font-semibold leading-[29px] tracking-[-0.04em] md:leading-[34px]"
        >
          Cada produção é pensada para transmitir valor, identidade e presença.
          <span class="text-[#151717]/35">
            Criamos imagens e vídeos que conectam marcas, pessoas e experiências
            de forma memorável.
          </span>
        </p>

        <span class="mt-10 inline-flex items-center">
        <Button href="#contato" text="Conheça nossas produções" variant="dark" class="mt-10" />
      </span>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-5 md:flex-row">
      {
        cards.map((card) => (
          <a
            href="/portfolio"
            class="group relative min-h-[380px] flex-1 overflow-hidden transition-all duration-700 ease-out md:hover:flex-[1.35]"
          >
            <img
              src={card.image}
              alt={card.alt}
              class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
            />

            <div class="absolute inset-0 bg-black/55" />

            <div class="relative z-10 flex h-full min-h-[380px] flex-col justify-between p-8 text-white md:p-10">
              <div class="w-full max-w-[340px]">
                <h3 class="whitespace-pre-line text-[33px] font-semibold leading-[38px] tracking-[-0.05em]">
                  {card.title}
                </h3>

                <p class="mt-8 max-w-[300px] text-[15px] leading-[23px] opacity-0 transition-opacity duration-500 group-hover:opacity-100">
                  {card.text}
                </p>
              </div>

              <span class="group/button inline-flex w-fit items-center gap-5 rounded-full border border-white/45 bg-black/10 px-5 py-2.5 text-[14px] font-semibold backdrop-blur-sm transition hover:bg-white hover:text-[#151717]">
                <span class="relative h-[18px] overflow-hidden">
                  <span class="block transition-transform duration-500 ease-out group-hover/button:-translate-y-full">
                    Ver portfólio
                  </span>

                  <span class="absolute left-0 top-full block transition-transform duration-500 ease-out group-hover/button:-translate-y-full">
                    Ver portfólio
                  </span>
                </span>

                <ArrowRight size={18} strokeWidth={1.8} />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>