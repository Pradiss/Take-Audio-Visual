---
import { ArrowRight } from "lucide-astro";

const cards = [
  {
    title: `Mortgage\nServices`,
    image: "/IMG_3604.webp",
    alt: "Mortgage Services",
    text: "Helping you secure your dream home with flexible mortgage options.",
  },
  {
    title: `Property\nManagement`,
    image: "/IMG_3606.webp",
    alt: "Property Management",
    text: "Let us handle the details so you can enjoy the rewards.",
  },
  {
    title: `Construction\nand Real Estate\nDevelopment`,
    image: "/IMG_3605.webp",
    alt: "Construction and Real Estate Development",
    text: "Guiding you through the intricacies of building and developing properties with expert insight and support.",
  },
];
---

<section id="features" class="bg-[#151717] text-white">
  <div class="mx-auto max-w-7xl px-6 py-24 md:py-32">
    <div class="grid gap-12 md:grid-cols-[1fr_1.25fr] md:items-start">
      <div>
        <h2
          class="text-[50px] font-medium leading-[56px] tracking-[-0.06em] md:text-[70px] md:leading-[72px]"
        >
          Support
          <span class="block">
            Beyond <span class="text-white/35">Buying</span>
          </span>
          <span class="block text-white/35">and Selling</span>
        </h2>
      </div>

      <div class="pt-2 md:max-w-[620px]">
        <p
          class="text-[24px] font-semibold leading-[29px] tracking-[-0.04em] md:leading-[34px]"
        >
          The real estate market never stands still — and neither do we.
          <span class="text-white/35">
            Our experts offer continued support beyond the sale, helping you
            maximize your investment.
          </span>
        </p>

        <a
          href="#servicos"
          class="mt-9 inline-flex items-center gap-6 rounded-full bg-white px-7 py-4 text-[15px] font-semibold text-[#151717] transition hover:bg-white/85"
        >
          Discover Our Services
          <ArrowRight size={20} strokeWidth={1.8} />
        </a>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-7 md:flex-row">
      {
        cards.map((card) => (
          <a
            href="#contato"
            class="group relative min-h-[380px] flex-1 overflow-hidden transition-all duration-700 ease-out md:hover:flex-[1.35]"
          >
            <img
              src={card.image}
              alt={card.alt}
              class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
            />

            <div class="absolute inset-0 bg-black/55" />

            <div class="relative z-10 flex h-full min-h-[380px] flex-col justify-between p-8 md:p-10">
              <div class="w-full max-w-[340px]">
                <h3 class="whitespace-pre-line text-[33px] font-semibold leading-[38px] tracking-[-0.05em]">
                  {card.title}
                </h3>

                <p class="mt-8 max-w-[300px] text-[15px] leading-[23px] opacity-0 transition-opacity duration-500 group-hover:opacity-100">
                  {card.text}
                </p>
              </div>

              <span class="group/button inline-flex w-fit items-center gap-5 rounded-full border border-white/45 bg-black/10 px-5 py-2.5 text-[14px] font-semibold backdrop-blur-sm transition hover:bg-white hover:text-[#151717]">
                <span class="relative h-[18px] overflow-hidden">
                  <span class="block transition-transform duration-500 ease-out group-hover/button:-translate-y-full">
                    Learn More
                  </span>

                  <span class="absolute left-0 top-full block transition-transform duration-500 ease-out group-hover/button:-translate-y-full">
                    Learn More
                  </span>
                </span>

                <ArrowRight size={18} strokeWidth={1.8} />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
