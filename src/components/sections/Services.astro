---
import { ArrowRight } from "lucide-astro";
import Button from "../global/Button.astro";

const services = [
  {
    number: "1",
    title: "Produtos",
    image: "/IMG_3604.webp",
    text: "Produção de imagens still para produtos, marcas e campanhas com acabamento profissional.",
  },
  {
    number: "2",
    title: "Arquitetura",
    image: "/IMG_3606.webp",
    text: "Fotografia e vídeo de ambientes para valorizar arquitetura e interiores.",
  },
  {
    number: "3",
    title: "Retrato Corporativo",
    image: "/IMG_3605.webp",
    text: "Retratos profissionais para fortalecer autoridade, posicionamento e presença digital com imagens que transmitem confiança.",
  },
];
---

<section id="servicos" class="services-section bg-[#151717] text-white">
  <div class="mx-auto grid max-w-7xl gap-12 px-6 py-24 md:grid-cols-[0.8fr_1.2fr] md:py-28">
    <div class="mb-8 flex items-center gap-2 text-sm sm:text-base">
      <span class="h-1.5 w-1.5 rounded-full bg-white"></span>
      <p>Serviços</p>
      
    </div>

    <div>
      <h2 class="services-title text-[48px] font-medium leading-[52px] tracking-[-0.04em] md:text-[64px] md:leading-[68px]">
        Como a TAKE
        <span class="block text-white/35">pode ajudar</span>
      </h2>
    </div>
  </div>

  <div class="services-list">
    {services.map((service) => (
      <a
        href="#contato"
        class="service-item group relative block overflow-hidden border-t border-white/15 last:border-b"
      >
        <div class="absolute inset-0 translate-y-full opacity-0 transition-all duration-700 ease-out group-hover:translate-y-0 group-hover:opacity-100">
          <img
            src={service.image}
            alt={service.title}
            class="h-full w-full translate-y-[18%] scale-110 object-cover transition-transform duration-1000 ease-out group-hover:translate-y-0"
          />
          <div class="absolute inset-0 bg-black/55"></div>
        </div>

        <div class="relative z-10 mx-auto grid max-w-7xl grid-cols-[70px_1fr] gap-8 px-6 py-16 md:grid-cols-[70px_420px_1fr_120px] md:items-center">
          <span class="flex h-9 w-9 items-center justify-center rounded-full border border-white text-sm">
            {service.number}
          </span>

          <p class="max-w-sm text-[18px] font-semibold leading-[26px]">
            {service.text}
          </p>

          <h3 class="text-[40px] font-medium leading-none tracking-[-0.06em] underline-offset-[0.12em] decoration-2 group-hover:underline md:text-[70px]">
            {service.title}
          </h3>

          <span class="hidden opacity-0 transition-all duration-500 group-hover:translate-x-3 group-hover:opacity-100 md:block">
            <ArrowRight size={100} strokeWidth={1.5} />
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="mx-auto grid max-w-7xl gap-12 px-6 py-24 md:py-28">
    <div>
      <h2 class="services-bottom-title max-w-3xl text-[33px] font-medium leading-[38px] tracking-[-0.04em] md:text-[33px] md:leading-[38px]">
        Nossa equipe acompanha você em cada etapa da produção
        <span class="text-white/35">
          com direção criativa, olhar estratégico e acabamento profissional.
        </span>
      </h2>
      <span class="mt-10 inline-flex items-center">
        <Button href="#contato" text="Fale com a Take" variant="light" class="mt-10" />
      </span>
     
    </div>
  </div>
</section>