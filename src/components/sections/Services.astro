---
import { ArrowRight } from "lucide-astro";
import Button from "../global/Button.astro";

const cards = [
  {
    number: "1",
    title: "Produtos",
    image: "produtos/IMG_3741.webp",
    alt: "Fotografia de Produtos",
    text: "Imagens profissionais para destacar detalhes, valorizar sua marca e aumentar a percepção de qualidade.",
  },
  {
    number: "2",
    title: "Arquitetura",
    image: "arquitetura/IMG_0154.webp",
    alt: "Arquitetura e Interiores",
    text: "Produções visuais para apresentar ambientes, projetos arquitetônicos e espaços com impacto visual.",
  },
  {
    number: "3",
    title: "Corporativo",
    image: "arquitetura/IMG_0039.webp",
    alt: "Retrato Corporativo",
    text: "Retratos profissionais para fortalecer autoridade, posicionamento e presença digital da sua marca.",
  },
  {
    number: "4",
    title: "Ensaios",
    image: "ensaios/IMG_3606.webp",
    alt: "Ensaio Fotográfico",
    text: "Ensaios fotográficos para criar conteúdo visual impactante e autêntico.",
  },
];
---

<section id="features" class="bg-[#151717] text-white">
  <div class="mx-auto max-w-[1760px] px-6 py-24 md:py-32">
    <div class="grid gap-12 md:grid-cols-[0.75fr_1.25fr] md:items-start">
      <p class="text-[22px] font-semibold tracking-[-0.04em]">Serviços</p>

      <div>
        <h2
          class="text-[clamp(3.5rem,4vw,5rem)] font-medium leading-[0.95] tracking-[-0.07em]"
        >
          Produções que vão<br />
          <span class="text-white/45">além da imagem.</span>
        </h2>

        <div class="mt-10">
          <Button
            href="#contato"
            text="Conheça nossas produções"
            variant="light"
          />
        </div>
      </div>
    </div>
  </div>

  <div class="border-y border-white/10">
    {
      cards.map((card) => (
        <a
          href="/portfolio"
          class="group relative block min-h-[430px] overflow-hidden border-b border-white/10 bg-black last:border-b-0 md:min-h-[510px]"
        >
          <img
            src={card.image}
            alt={card.alt}
            class="absolute inset-0 h-full w-full scale-110 object-cover opacity-0 transition-all duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-100 group-hover:opacity-70"
          />

          <div class="absolute inset-0 bg-black transition duration-700 group-hover:bg-black/25" />

          <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/25 to-black/60 opacity-0 transition duration-700 group-hover:opacity-100" />

          <div class="relative z-10 mx-auto grid min-h-[430px] max-w-[1750px] grid-cols-[80px_1fr] items-center gap-6 px-6 py-10 md:min-h-[510px] md:grid-cols-[120px_0.8fr_1.2fr_220px] md:py-14">
            <div class="flex h-12 w-12 items-center justify-center rounded-full border border-white/45 text-[18px] font-medium text-white/70 transition duration-500 group-hover:border-white group-hover:text-white">
              {card.number}
            </div>

            <p class="max-w-[360px] text-[19px] font-semibold leading-[1.35] tracking-[-0.04em] text-white/55 transition duration-500 group-hover:text-white md:text-[24px]">
              {card.text}
            </p>

            <h3 class="col-span-2 text-[clamp(4rem,9vw,9rem)] font-medium leading-none tracking-[-0.09em] text-white/55 transition duration-500 group-hover:text-white md:col-span-1">
              {card.title}
            </h3>

            <div class="hidden justify-end md:flex">
              <ArrowRight
                class="h-28 w-28 translate-x-[-20px] text-white opacity-0 transition-all duration-500 group-hover:translate-x-0 group-hover:opacity-100"
                strokeWidth={1.2}
              />
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>
