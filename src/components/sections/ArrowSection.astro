---
const arrows = [
  {
    image: "produtos/IMG_3739.webp",
    alt: "Imagem audiovisual 1",
  },
  {
    image: "arquitetura/IMG_0044.webp",
    alt: "Imagem audiovisual 2",
  },
  {
    image: "arquitetura/IMG_0039.webp",
    alt: "Imagem audiovisual 3",
  },
  {
    image: "ensaios/IMG_3634.webp",
    alt: "Imagem audiovisual 4",
  },
];
---

<section id="arrows" class="relative bg-[#f4efe7]  px-6 py-24 text-black md:py-28">
  <div class="mx-auto max-w-7xl text-center">
    <h2 class="arrows-title text-[42px] font-medium leading-[48px] tracking-[-0.04em] md:text-[64px] md:leading-[68px]">
      Não é só sobre
      <span class="text-black/30">audiovisual.</span>
    </h2>

    <div class="arrows-wrapper mt-14 flex justify-center">
      {arrows.map((arrow) => (
        <div class="arrow-img">
          <img src={arrow.image} alt={arrow.alt} />
        </div>
      ))}
    </div>

    <p class="arrows-text mx-auto mt-12 max-w-4xl text-[24px] font-medium leading-[34px] tracking-[-0.04em] md:text-[34px] md:leading-[40px]">
      É sobre identidade. Direção. Impacto.
      <br />
      Sua marca não está apenas buscando aparecer.
      <span class="text-black/30">
        Ela está buscando ser lembrada.
      </span>
    </p>
  </div>
</section>

<style>
  .arrows-wrapper {
    display: flex;
    align-items: center;
  }

  .arrow-img {
    width: 380px;
    height: 440px;
    margin-left: -105px;
    overflow: hidden;
    background: #111;
    clip-path: polygon(
      0 0,
      50% 0,
      100% 50%,
      50% 100%,
      0 100%,
      50% 50%
    );
  }

  .arrow-img:first-child {
    margin-left: 0;
  }

  .arrow-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .arrow-img {
      width: 130px;
      height: 150px;
      margin-left: -40px;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(
    ".arrows-title",
    { y: 35, opacity: 0 },
    {
      y: 0,
      opacity: 1,
      ease: "power2.out",
      scrollTrigger: {
        trigger: "#arrows",
        start: "top 85%",
        end: "top 50%",
        scrub: 1.2,
      },
    }
  );

  gsap.fromTo(
    ".arrow-img",
    { y: 45, opacity: 0, scale: 0.97 },
    {
      y: 0,
      opacity: 1,
      scale: 1,
      stagger: 0.08,
      ease: "power2.out",
      scrollTrigger: {
        trigger: ".arrows-wrapper",
        start: "top 85%",
        end: "top 50%",
        scrub: 1.5,
      },
    }
  );

  gsap.fromTo(
    ".arrows-text",
    { y: 35, opacity: 0 },
    {
      y: 0,
      opacity: 1,
      ease: "power2.out",
      scrollTrigger: {
        trigger: ".arrows-text",
        start: "top 90%",
        end: "top 65%",
        scrub: 1.2,
      },
    }
  );
</script>