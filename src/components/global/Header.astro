<header
  id="site-header"
  class="fixed left-0 top-0 z-50 w-full translate-y-0 bg-transparent transition-all duration-300"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
    <a href="/" class="flex items-center">
      <img
        src="/logo1.webp"
        alt="TAKE Audiovisual"
        class="w-full max-w-[120px]"
      />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-medium text-black/70 md:flex">
      <a href="#inicio" class="hover:text-black">Início</a>
      <a href="#sobre" class="hover:text-black">Sobre</a>
      <a href="#servicos" class="hover:text-black">Serviços</a>
      <a href="#portfolio" class="hover:text-black">Portfólio</a>
      <a href="#contato" class="hover:text-black">Contato</a>
    </nav>

    <a
      href="#contato"
      class="rounded-full bg-black px-5 py-2 text-sm font-semibold text-white transition hover:scale-105 hover:bg-red-600"
    >
      Orçamento
    </a>
  </div>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.querySelector("#site-header");
    let lastScroll = window.scrollY;

    window.addEventListener("scroll", () => {
      const currentScroll = window.scrollY;

      if (currentScroll <= 20) {
        header.style.transform = "translateY(0)";
        header.classList.remove("bg-white", "shadow-md");
        header.classList.add("bg-transparent");
      } else if (currentScroll > lastScroll) {
        header.style.transform = "translateY(-100%)";
      } else {
        header.style.transform = "translateY(0)";
        header.classList.remove("bg-transparent");
        header.classList.add("bg-white", "shadow-md");
      }

      lastScroll = currentScroll;
    });
  });
</script>